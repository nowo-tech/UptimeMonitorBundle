{# Sidebar monitor row: pill, name, history bar. #}
{% set status = latest ? latest.status.value : 'unknown' %}
{% set pill_class = monitor.paused ? 'paused' : status %}
<li class="uptime-sidebar-item{% if nested %} uptime-sidebar-item--child{% endif %}{% if monitor.type.value == 'group' and not nested %} uptime-sidebar-item--group{% endif %}{% if events_filter_monitor_id is defined and events_filter_monitor_id == monitor.id %} is-selected{% endif %}"
    data-monitor-id="{{ monitor.id }}"
    data-sidebar-row
    role="button"
    tabindex="0">
    <span class="uptime-sidebar-pill uptime-sidebar-pill-{{ pill_class }}" data-uptime-pill title="24h uptime">
        {% if monitor.paused %}—{% elseif row.uptime_24h is not null %}{{ row.uptime_24h|number_format(0) }}%{% else %}—{% endif %}
    </span>
    <span class="uptime-sidebar-label">
        <a href="{{ path('nowo_uptime_monitor_show', { tenantSlug: tenant_slug, id: monitor.id }) }}" class="uptime-sidebar-name" data-sidebar-name>{{ monitor.name }}</a>
    </span>
    <span class="uptime-sidebar-history" data-history-container>
        {% include '@NowoUptimeMonitorBundle/_history_bar.html.twig' with {
            history: row.history,
            bar_theme: heartbeat_bar_theme|default('normal'),
        } %}
        {% if elapsed_time_display|default('show') != 'none' and row.history|length > 0 %}
            {% set last = row.history|last %}
            {% if last.checked_at is defined and last.checked_at %}
                <span class="uptime-sidebar-elapsed{{ (elapsed_time_display|default('show')) == 'show_line' ? ' uptime-sidebar-elapsed--line' : '' }}">
                    {{ last.checked_at|date('H:i') }}
                </span>
            {% endif %}
        {% endif %}
    </span>
</li>
