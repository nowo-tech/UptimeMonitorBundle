<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}OTP Input Demo{% endblock %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background: #f5f7fb;
        }
        .otp-demo-shell {
            max-width: 760px;
        }
        .otp-demo-card {
            border: 1px solid #e9edf5;
            border-radius: 16px;
            box-shadow: 0 8px 30px rgba(17, 24, 39, 0.06);
        }
        .otp-demo-grid {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
        }
        .otp-demo-digit {
            width: 52px;
            min-width: 52px;
            height: 56px;
            font-size: 1.4rem;
            font-weight: 600;
            border-radius: 10px;
            padding: 0;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-dark bg-dark mb-4">
        <div class="container">
            <a class="navbar-brand" href="{{ path('app_demo_index') }}">OTP Input Bundle Demo</a>
        </div>
    </nav>
    {% block body %}{% endblock %}
</body>
</html>
