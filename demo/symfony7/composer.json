{
    "name": "nowo-tech/uptime-monitor-demo-symfony7",
    "description": "Demo for Uptime Monitor Bundle - Symfony 7",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.2",
        "nowo-tech/uptime-monitor-bundle": "@dev",
        "doctrine/doctrine-bundle": "^2.13 || ^3.0",
        "doctrine/orm": "^2.13 || ^3.0",
        "symfony/asset": "^7.2",
        "symfony/console": "^7.2",
        "symfony/dotenv": "^7.2",
        "symfony/form": "^7.2",
        "symfony/validator": "^7.2",
        "symfony/flex": "^2.0",
        "symfony/framework-bundle": "^7.2",
        "symfony/messenger": "^7.2",
        "symfony/runtime": "^7.2",
        "symfony/translation": "^7.2",
        "symfony/scheduler": "^7.2",
        "symfony/security-bundle": "^7.2",
        "symfony/twig-bundle": "^7.2",
        "symfony/yaml": "^7.2",
        "symfony/mercure-bundle": "^0.4"
    },
    "config": {
        "allow-plugins": {
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        },
        "post-install-cmd": ["@auto-scripts"],
        "post-update-cmd": ["@auto-scripts"],
        "test": "php bin/console about --env=dev",
        "test-coverage": "@composer test"
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "7.4.*"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "/var/uptime-monitor-bundle"
        }
    ],
    "require-dev": {
        "nowo-tech/twig-inspector-bundle": "*",
        "symfony/debug-bundle": "^7.2",
        "symfony/var-dumper": "^7.2",
        "symfony/web-profiler-bundle": "^7.2"
    }
}
