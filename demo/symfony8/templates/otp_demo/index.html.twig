{% extends 'base.html.twig' %}

{% block body %}
<div class="container py-4 otp-demo-shell">
    <div class="card otp-demo-card">
        <div class="card-body p-4 p-md-5">
            <h1 class="mb-2">OTP FormType demos</h1>
            <p class="text-muted mb-4">Each example uses a different configuration (length, numeric-only, uppercase, help text).</p>
            <ul class="list-group list-group-flush border rounded overflow-hidden">
                {% for slug, cfg in examples %}
                    <li class="list-group-item d-flex justify-content-between align-items-center py-3">
                        <div>
                            <a href="{{ path('app_demo_otp', { slug: slug }) }}" class="fw-semibold text-decoration-none">{{ cfg.title }}</a>
                            <div class="small text-muted mt-1">{{ cfg.help }}</div>
                        </div>
                        <span class="badge bg-secondary rounded-pill">{{ slug }}</span>
                    </li>
                {% endfor %}
            </ul>
        </div>
    </div>
</div>
{% endblock %}
